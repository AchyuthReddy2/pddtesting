{
  "name": "villageconnect-monorepo",
  "version": "1.0.0",
  "description": "VillageConnect workspace containing frontend and backend projects",
  "private": true,
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "install:backend": "npm install --prefix backend",
    "install:all": "npm run install:frontend && npm run install:backend",
    "start:frontend": "npm start --prefix frontend",
    "start:backend": "npm run dev --prefix backend",
    "seed:backend": "npm run seed --prefix backend",
    "test:selenium": "node tests/selenium.test.js",
    "test:selenium:e2e": "node tests/selenium_e2e.test.js"
  },
  "devDependencies": {
    "eas-cli": "^20.1.0",
    "selenium-webdriver": "^4.20.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
